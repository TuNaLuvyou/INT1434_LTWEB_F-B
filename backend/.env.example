# ─── Database (PostgreSQL / Supabase) ────────────────────────────────────────
# Kết nối qua Pooler (port 6543) — dùng khi chạy server (dev/production)
DATABASE_URL=""

# Kết nối trực tiếp (port 5432) — dùng khi chạy migrate / seed
DIRECT_URL=""

# ─── Authentication (JWT) ─────────────────────────────────────────────────────
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# ─── Cloudinary (Upload ảnh món ăn) ──────────────────────────────────────────
# Đăng ký tài khoản miễn phí tại https://cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ─── Server ───────────────────────────────────────────────────────────────────
# Cổng chạy Backend Server (mặc định là 5001)
PORT=5000
NODE_ENV=development

# ─── CORS / URLs ──────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
NEXTJS_URL="http://localhost:3000"
REVALIDATION_SECRET="restoflow_revalidation_secret"

# ─── Nodemailer SMTP (Z-Report Email) ────────────────────────────────────────
# Với Gmail: bật 2FA rồi tạo App Password tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="RestoFlow POS <your_email@gmail.com>"
