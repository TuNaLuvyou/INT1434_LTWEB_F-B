# ==============================================================================
# 1. DATABASE (PostgreSQL / Supabase)
# ==============================================================================
# Kết nối qua Pooler (port 6543) — dùng khi chạy server (dev/production)
DATABASE_URL="postgresql://[db-user]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Kết nối trực tiếp (port 5432) — dùng khi chạy migrate / seed
DIRECT_URL="postgresql://[db-user]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ==============================================================================
# 2. AUTHENTICATION (JWT)
# ==============================================================================
JWT_SECRET="your_jwt_secret_key_here"
JWT_EXPIRES_IN="7d"
# Lưu ý: JWT_ACCESS_SECRET phải khớp với FRONTEND để middleware hoạt động
JWT_ACCESS_SECRET="your_jwt_access_secret_here"
JWT_REFRESH_SECRET="your_jwt_refresh_secret_here"

# ==============================================================================
# 3. CLOUDINARY (Upload ảnh tĩnh)
# ==============================================================================
# Đăng ký tài khoản miễn phí tại: https://cloudinary.com
CLOUDINARY_CLOUD_NAME="your_cloud_name_here"
CLOUDINARY_API_KEY="your_api_key_here"
CLOUDINARY_API_SECRET="your_api_secret_here"

# ==============================================================================
# 4. SERVER CONFIGURATION
# ==============================================================================
# Cổng chạy Backend Server (mặc định: 5000)
PORT=5000
NODE_ENV="development"

# ==============================================================================
# 5. CORS / URLs
# ==============================================================================
FRONTEND_URL="http://localhost:3000"
NEXTJS_URL="http://localhost:3000"
# Chuỗi bí mật để đồng bộ revalidate với frontend
REVALIDATION_SECRET="your_revalidation_secret_here"

# ==============================================================================
# 6. EMAIL SMTP (Nodemailer / Z-Report)
# ==============================================================================
# Lưu ý Gmail: Bật 2FA -> Tạo App Password tại https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password_here"
SMTP_FROM="HiAI-MenuGo POS <your_email@gmail.com>"
