# Đường dẫn kết nối database qua Pooler (ví dụ: port 6543 của Supabase, dùng cho dev/run)
DATABASE_URL=""

# Đường dẫn kết nối trực tiếp database (ví dụ: port 5432 của Supabase, dùng cho migration/seed)
DIRECT_URL=""

# Khóa bí mật chung cho JWT và thời hạn (Cấu hình cũ)
JWT_SECRET=""
JWT_EXPIRES_IN=""

# Khóa bảo mật ký Access Token & Refresh Token (Khớp với cấu hình xác thực mới)
JWT_ACCESS_SECRET=""
JWT_REFRESH_SECRET=""

# Thông tin xác thực lưu trữ đám mây Cloudinary để tải ảnh món ăn
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Cổng chạy server Backend và môi trường hiện tại (development/production)
PORT=""
NODE_ENV=""

# URL của Frontend dùng để phân quyền CORS và Socket.io
FRONTEND_URL=""

# Khóa bí mật dùng để gọi API Revalidate cache tĩnh phía Frontend Next.js
REVALIDATION_SECRET=""
