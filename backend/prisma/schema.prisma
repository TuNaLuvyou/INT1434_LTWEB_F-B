generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// SAAS CORE MODELS
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branches    Branch[]
  tenantUsers TenantUser[]
  customRoles CustomRole[] @relation("TenantRoles")

  categories    Category[]
  menuItems     MenuItem[]
  tables        Table[]
  tableSessions TableSession[]
  orderItems    OrderItem[]
  payments      Payment[]
  vouchers      Voucher[]
  ingredients   Ingredient[]
  inventoryLogs InventoryLog[]
  shifts        Shift[]
  systemConfig  SystemConfig?
  auditLogs     AuditLog[]
  branding      TenantBranding?
  bankAccounts  TenantBankAccount[]
  subscription  TenantSubscription?
}

model Branch {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  address   String?
  isActive  Boolean  @default(true)
  isLocked  Boolean  @default(false) // Bị khoá do gói cước không đủ
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tables            Table[]
  tableSessions     TableSession[]
  payments          Payment[]
  shifts            Shift[]
  inventoryLogs     InventoryLog[]
  bankAccounts      TenantBankAccount[]
  tenantUsers       TenantUser[]
  categoryOverrides BranchCategory[]
  menuOverrides     BranchMenuItem[]
  ingredientStocks  BranchIngredient[]
  voucherBranches   VoucherBranch[]

  @@index([tenantId])
}

model TenantBranding {
  id             String   @id @default(uuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Platform-level user
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role // Platform role mapping (for legacy compat)
  domain       String? // Domain của tenant, dùng để phân biệt user giữa các quán
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantUsers TenantUser[]
  shifts      Shift[] // legacy mapping, ideally via TenantUser
}

model TenantUser {
  id         String      @id @default(uuid())
  tenantId   String
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId     String?
  customRole CustomRole? @relation(fields: [roleId], references: [id])
  isOwner    Boolean     @default(false)
  branchId   String?
  branch     Branch?     @relation(fields: [branchId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([tenantId, userId])
  @@index([branchId])
}

// Thay thế enum Role cũ bằng CustomRole + Permission cho chuẩn RBAC
model CustomRole {
  id          String   @id @default(uuid())
  tenantId    String
  tenant      Tenant   @relation("TenantRoles", fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  tenantUsers TenantUser[]

  @@unique([tenantId, name])
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique // e.g., 'MENU_CREATE', 'ORDER_VIEW'
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         CustomRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// BUSINESS MODELS
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MANAGER
  KITCHEN
  CASHIER
  PLATFORM_ADMIN // Added for platform-level
}

model SystemConfig {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  restaurantName    String
  isGeofenceEnabled Boolean  @default(false)
  restaurantLat     Float?
  restaurantLng     Float?
  maxOrderDistance  Int      @default(100)
  updatedAt         DateTime @updatedAt
}


model Category {
  id        String     @id @default(uuid())
  tenantId  String
  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  sortOrder Int        @default(0)
  menuItems MenuItem[]
  branches  BranchCategory[]

  @@unique([tenantId, slug])
}

model BranchCategory {
  id        String   @id @default(uuid())
  branchId  String
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  categoryId String
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  isEnabled Boolean  @default(true)
  sortOrder Int      @default(0)

  @@unique([branchId, categoryId])
  @@index([branchId])
}

model MenuItem {
  id          String      @id @default(uuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  imageUrl    String?
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  isSoldOut   Boolean     @default(false)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  bom         BOM[]
  branchOverrides BranchMenuItem[]

  @@index([categoryId])
  @@index([tenantId])
}

model BranchMenuItem {
  id         String   @id @default(uuid())
  branchId   String
  branch     Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  price      Decimal? @db.Decimal(10, 2) // null = dùng giá tenant
  isSoldOut  Boolean? // null = dùng isSoldOut tenant
  isActive   Boolean? // null = dùng isActive tenant
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([branchId, menuItemId])
  @@index([branchId])
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  ORDERING
  FOOD_READY
  WAITING_PAYMENT
  COMPLETED
  DISABLED
}

model Table {
  id          String         @id @default(uuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableNumber Int
  label       String
  status      TableStatus
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  sessions    TableSession[]

  @@unique([branchId, tableNumber])
  @@index([tenantId])
}

enum SessionStatus {
  OPEN
  PAID
  CANCELLED
}

model TableSession {
  id            String        @id @default(uuid())
  tenantId      String
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String
  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  tableId       String
  table         Table         @relation(fields: [tableId], references: [id])
  status        SessionStatus
  version       Int           @default(0)
  openedAt      DateTime      @default(now())
  lockedAt      DateTime?
  closedAt      DateTime?
  createdViaPos Boolean       @default(false)
  orderItems    OrderItem[]
  payment       Payment?

  @@index([tableId])
  @@index([tenantId])
  @@index([branchId])
}

enum OrderItemStatus {
  CART
  PENDING
  PREPARING
  DONE
  DELIVERED
  VOID
}

model OrderItem {
  id         String          @id @default(uuid())
  tenantId   String
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId  String
  session    TableSession    @relation(fields: [sessionId], references: [id])
  menuItemId String
  menuItem   MenuItem        @relation(fields: [menuItemId], references: [id])
  qty        Int
  unitPrice  Decimal         @db.Decimal(10, 2)
  note       String?
  status     OrderItemStatus
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  @@unique([sessionId, menuItemId, status])
  @@index([sessionId])
  @@index([sessionId, status])
  @@index([menuItemId])
  @@index([tenantId])
}

model Ingredient {
  id             String         @id @default(cuid())
  tenantId       String
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  unit           String
  stock          Decimal
  minStock       Decimal
  totalExported  Decimal        @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  bom            BOM[]
  logs           InventoryLog[]
  branchStocks   BranchIngredient[]

  @@index([tenantId])
}

model BranchIngredient {
  id            String   @id @default(cuid())
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ingredientId  String
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  stock         Decimal  @default(0)
  importPrice   Decimal? @db.Decimal(12, 2) // giá nhập riêng theo chi nhánh
  lowStockThreshold Decimal? // ngưỡng cảnh báo riêng, null = dùng minStock của ingredient
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([branchId, ingredientId])
  @@index([branchId])
}

model BOM {
  id           String     @id @default(cuid())
  menuItemId   String
  menuItem     MenuItem   @relation(fields: [menuItemId], references: [id])
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  quantity     Decimal

  @@unique([menuItemId, ingredientId])
  @@index([menuItemId])
  @@index([ingredientId])
}

model InventoryLog {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId     String
  branch       Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  delta        Decimal
  reason       String
  orderId      String?
  createdBy    String?
  createdAt    DateTime   @default(now())

  @@index([ingredientId])
  @@index([createdAt])
  @@index([tenantId])
  @@index([branchId])
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model Shift {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String
  branch        Branch      @relation(fields: [branchId], references: [id], onDelete: Cascade)
  cashierId     String
  cashier       User        @relation(fields: [cashierId], references: [id])
  openFloat     Decimal
  closeFloat    Decimal?
  cashTotal     Decimal?
  transferTotal Decimal?
  orderCount    Int?
  status        ShiftStatus
  openedAt      DateTime    @default(now())
  closedAt      DateTime?
  payments      Payment[]

  @@index([cashierId])
  @@index([status])
  @@index([tenantId])
  @@index([branchId])
}

enum PaymentMethod {
  CASH
  TRANSFER
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

model Payment {
  id             String        @id @default(cuid())
  tenantId       String
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId       String
  branch         Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  sessionId      String        @unique
  session        TableSession  @relation(fields: [sessionId], references: [id])
  shiftId        String
  shift          Shift         @relation(fields: [shiftId], references: [id])
  subtotal       Decimal
  discountAmount Decimal       @default(0)
  total          Decimal
  method         PaymentMethod
  status         PaymentStatus @default(SUCCESS)
  paymentCode    String?       @unique
  provider       String?       // "CASH", "VIETQR", "MOMO"
  transactionId  String?
  voucherId      String?
  voucher        Voucher?      @relation(fields: [voucherId], references: [id])
  paidAt         DateTime      @default(now())

  @@index([shiftId])
  @@index([paidAt])
  @@index([tenantId])
  @@index([branchId])
}

model TenantBankAccount {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branchId      String?
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  bankId        String
  bankName      String
  accountNumber String
  accountName   String
  isDefault     Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
}

enum DiscountType {
  PERCENT
  FIXED
}

model Voucher {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code          String
  discountType  DiscountType
  discountValue Decimal
  maxUsage      Int?
  usedCount     Int          @default(0)
  isActive      Boolean      @default(true)
  expiredAt     DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  payments      Payment[]
  branches      VoucherBranch[]

  @@unique([tenantId, code])
}

model VoucherBranch {
  id        String  @id @default(uuid())
  voucherId String
  voucher   Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  branchId  String
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([voucherId, branchId])
  @@index([branchId])
}


// ─────────────────────────────────────────────────────────────────────────────
// SAAS BILLING MODELS
// ─────────────────────────────────────────────────────────────────────────────

enum BillingCycle {
  MONTHLY
  YEARLY
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique // 'Starter', 'Professional', 'Enterprise'
  description   String?
  price         Decimal  @db.Decimal(10, 2)
  currency      String   @default("VND")
  billingCycle  BillingCycle @default(MONTHLY)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  features      PlanFeature[]
  limits        UsageLimit[]
  subscriptions TenantSubscription[]
}

model PlanFeature {
  id       String @id @default(uuid())
  planId   String
  plan     SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  code     String // e.g., 'KDS_ACCESS', 'PROMOTION_ENGINE', 'WHITE_LABEL', 'API_ACCESS'
  isActive Boolean @default(true)

  @@unique([planId, code])
}

model UsageLimit {
  id           String @id @default(uuid())
  planId       String
  plan         SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  resourceCode String // e.g., 'BRANCH', 'TABLE', 'USER', 'MENU_ITEM'
  maxLimit     Int    // e.g. 1 for Starter, 5 for Professional, 9999 for Enterprise

  @@unique([planId, resourceCode])
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

model TenantSubscription {
  id              String   @id @default(uuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId          String
  plan            SubscriptionPlan @relation(fields: [planId], references: [id])
  status          SubscriptionStatus @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime
  trialEndsAt     DateTime?
  cancelAtPeriodEnd Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoices        SubscriptionInvoice[]
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  VOID
  UNCOLLECTIBLE
}

model SubscriptionInvoice {
  id             String   @id @default(uuid())
  subscriptionId String
  subscription   TenantSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount         Decimal  @db.Decimal(10, 2)
  status         InvoiceStatus @default(DRAFT)
  dueDate        DateTime
  paidAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payments       SubscriptionPayment[]
}

model SubscriptionPayment {
  id            String   @id @default(uuid())
  invoiceId     String
  invoice       SubscriptionInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount        Decimal  @db.Decimal(10, 2)
  provider      String   // e.g., 'STRIPE', 'VN_PAY', 'BANK_TRANSFER'
  transactionId String?
  status        String   // e.g., 'SUCCESS', 'FAILED'
  createdAt     DateTime @default(now())
}
