# =========================================================================
# RESTOFLOW MONOREPO - MASTER ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' inside the root folder or 'backend/' folder.
# DO NOT commit the actual '.env' file containing your secrets to Git!
# =========================================================================

# -------------------------------------------------------------------------
# 1. DATABASE CONFIGURATION (PostgreSQL / Supabase)
# -------------------------------------------------------------------------
# DATABASE_URL: Cổng Transaction (6543) - Dùng cho runtime (đọc/ghi dữ liệu từ Express/Next.js)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-[YOUR-REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# DIRECT_URL: Cổng Session (5432) - Bắt buộc dùng cho Prisma CLI (migrate, seed) để tránh lỗi Pgbouncer
DIRECT_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-[YOUR-REGION].pooler.supabase.com:5432/postgres"

# -------------------------------------------------------------------------
# 2. AUTHENTICATION & SECURITY (JWT)
# -------------------------------------------------------------------------
# JWT_SECRET: Khóa ký mã hóa bảo mật token (Hãy đổi thành một chuỗi ngẫu nhiên, dài và khó đoán)
JWT_SECRET="YOUR_SUPER_SECRET_JWT_KEY_HERE_1234567890"
JWT_EXPIRES_IN="7d"

# -------------------------------------------------------------------------
# 3. THIRD-PARTY SERVICES & INTEGRATIONS (Sẽ cấu hình sau)
# -------------------------------------------------------------------------
# CLOUDINARY_URL: Lưu trữ và tối ưu hóa hình ảnh thực đơn (Menu Items Image Uploads)
CLOUDINARY_URL="cloudinary://[YOUR-API-KEY]:[YOUR-API-SECRET]@[YOUR-CLOUD-NAME]"

# -------------------------------------------------------------------------
# 4. SERVER RUNTIME SETTINGS
# -------------------------------------------------------------------------
PORT=5000
NODE_ENV="development"
