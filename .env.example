# Database (Supabase)
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.your-project-ref:your-password@aws-your-region.pooler.supabase.com:5432/postgres"

# JWT Auth
JWT_SECRET="your_super_secret_jwt_key_here"
JWT_EXPIRES_IN="7d"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Server Ports
PORT=5000
NODE_ENV="development"

# APIs / Socket / Revalidation URLs
NEXT_PUBLIC_API_URL="http://127.0.0.1:5000"
FRONTEND_URL="http://127.0.0.1:3000"
NEXTJS_URL="http://127.0.0.1:3000"
REVALIDATION_SECRET="restoflow_revalidation_secret"
