# ─── Backend API URL (REST & Socket.io) ──────────────────────────────────────
# Dùng 127.0.0.1 thay vì localhost để tránh lỗi IPv6 trên một số máy
# Số port phải khớp với PORT trong backend/.env
NEXT_PUBLIC_API_URL="http://127.0.0.1:5000"

# ─── Database (PostgreSQL / Supabase) ────────────────────────────────────────
# Next.js Server Actions gọi thẳng vào DB — cần thiết cho SSR & Server Components
DATABASE_URL=""
DIRECT_URL=""

# ─── Authentication (phải khớp với backend) ───────────────────────────────────
# Copy y hệt giá trị JWT_ACCESS_SECRET từ backend/.env
JWT_ACCESS_SECRET=""

# ─── On-Demand Revalidation ───────────────────────────────────────────────────
# Phải khớp với giá trị REVALIDATION_SECRET bên backend
REVALIDATION_SECRET="hiaimenugo_revalidation_secret"
