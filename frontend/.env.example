# ==============================================================================
# 1. BACKEND API URL (REST & Socket.io)
# ==============================================================================
# Khuyến nghị: Dùng 127.0.0.1 thay vì localhost để tránh lỗi IPv6 trên Windows
# Port (5000) phải khớp với thiết lập PORT bên backend/.env
NEXT_PUBLIC_API_URL="http://127.0.0.1:5000"

# ==============================================================================
# 2. DATABASE (PostgreSQL / Supabase)
# ==============================================================================
# Bắt buộc cho Server Actions & Server Components của Next.js
# Cần copy y hệt từ backend/.env sang
DATABASE_URL="postgresql://[db-user]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://[db-user]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ==============================================================================
# 3. AUTHENTICATION & SECURITY
# ==============================================================================
# BẮT BUỘC: Phải giống hệt JWT_ACCESS_SECRET bên backend/.env
JWT_ACCESS_SECRET="your_jwt_access_secret_here"

# ==============================================================================
# 4. ON-DEMAND REVALIDATION (ISR)
# ==============================================================================
# BẮT BUỘC: Phải giống hệt REVALIDATION_SECRET bên backend/.env
REVALIDATION_SECRET="your_revalidation_secret_here"
